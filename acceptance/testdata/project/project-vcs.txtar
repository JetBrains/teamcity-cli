# Test project vcs subcommands.

[!has_token] skip 'requires authentication token'

# List VCS roots
exec teamcity project vcs list --project CLI --no-input
stdout 'ID'
stdout 'NAME'
stdout 'TYPE'
stdout 'PROJECT'
! stderr 'Error'

# List --json
exec teamcity project vcs list --project CLI --json --no-input
stdout '"count"'
stdout '"id"'
stdout '"vcs-root"'
! stderr 'Error'

# List --json=id,name field selection
exec teamcity project vcs list --project CLI --json=id,name --no-input
stdout '"id"'
stdout '"name"'
! stderr 'Error'

# List --plain
exec teamcity project vcs list --project CLI --plain --no-input
stdout '.'
! stderr 'Error'

# List requires --project
! exec teamcity project vcs list --no-input
stderr 'required'

# Find a VCS root ID for view test
exec teamcity api '/app/rest/vcs-roots?locator=affectedProject:CLI,count:1&fields=vcs-root(id)' --raw --no-input
extract '"id":"([^"]+)"' VCS_ROOT_ID

# View VCS root
exec teamcity project vcs view $VCS_ROOT_ID --no-input
stdout 'ID:'
stdout 'Type:'
stdout 'Project:'
! stderr 'Error'

# View --json
exec teamcity project vcs view $VCS_ROOT_ID --json --no-input
stdout '"id"'
stdout '"properties"'
! stderr 'Error'

# View not found
! exec teamcity project vcs view NonExistentVcsRoot123456 --no-input
stderr '.'

# Test config get, set, reset, and list lifecycle.

# List shows default_server
exec teamcity config list --no-input
stdout 'default_server='

# Get default_server
exec teamcity config get default_server --no-input
stdout '.'

# Set per-server settings on the current default server
exec teamcity config get default_server --no-input
stdout2env DEFAULT_SERVER

exec teamcity config set ro true --server $DEFAULT_SERVER --no-input
stdout 'Set ro'

exec teamcity config get ro --server $DEFAULT_SERVER --no-input
stdout 'true'

exec teamcity config set guest true --server $DEFAULT_SERVER --no-input
stdout 'Set guest'

# List shows the server settings
exec teamcity config list --no-input
stdout 'ro=true'
stdout 'guest=true'

# Reset ro
exec teamcity config reset ro --server $DEFAULT_SERVER --no-input
stdout 'Reset ro'

exec teamcity config get ro --server $DEFAULT_SERVER --no-input
stdout 'false'

# Reset guest
exec teamcity config reset guest --server $DEFAULT_SERVER --no-input

# JSON output
exec teamcity config list --json --no-input
stdout '"default_server"'
stdout '"servers"'

# Invalid key
! exec teamcity config get nonexistent --no-input
stderr 'unknown key'

! exec teamcity config set nonexistent val --no-input
stderr 'unknown key'

# Invalid bool
! exec teamcity config set ro maybe --server $DEFAULT_SERVER --no-input
stderr 'invalid boolean'

# Unknown server rejected for default_server
! exec teamcity config set default_server typo.example.com --no-input
stderr 'not found in configuration'

# Test config get, set, reset, and list lifecycle.
# Uses TEAMCITY_URL (set by CI) as the server target.

# List shows default_server key
exec teamcity config list --no-input
stdout 'default_server='

# Set per-server settings using the env server
exec teamcity config set ro true --server $TEAMCITY_URL --no-input
stdout 'Set ro'

exec teamcity config get ro --server $TEAMCITY_URL --no-input
stdout 'true'

exec teamcity config set guest true --server $TEAMCITY_URL --no-input
stdout 'Set guest'

# List shows the server settings
exec teamcity config list --no-input
stdout 'ro=true'
stdout 'guest=true'

# Reset ro
exec teamcity config reset ro --server $TEAMCITY_URL --no-input
stdout 'Reset ro'

exec teamcity config get ro --server $TEAMCITY_URL --no-input
stdout 'false'

# Reset guest back
exec teamcity config reset guest --server $TEAMCITY_URL --no-input

# JSON output
exec teamcity config list --json --no-input
stdout '"default_server"'
stdout '"servers"'

# Invalid key
! exec teamcity config get nonexistent --no-input
stderr 'unknown key'

! exec teamcity config set nonexistent val --no-input
stderr 'unknown key'

# Invalid bool
! exec teamcity config set ro maybe --server $TEAMCITY_URL --no-input
stderr 'invalid boolean'

# Unknown server rejected for default_server
! exec teamcity config set default_server typo.example.com --no-input
stderr 'not found in configuration'

# LangSmith (EU region)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=teamcity-cli

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# TeamCity server for eval tasks
TEAMCITY_URL=https://buildserver.labs.intellij.net
TEAMCITY_TOKEN=...

# Eval configuration
# Model to test (change to compare: claude-sonnet-4-5-20250929, claude-opus-4-6, claude-haiku-4-5-20251001)
BENCH_CC_MODEL=claude-sonnet-4-5-20250929
BENCH_TIMEOUT=300
# Set to 1 to run Claude Code locally instead of Docker
# BENCH_LOCAL=1
